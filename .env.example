SHOWROOMFLOW_ENVIRONMENT=development
SHOWROOMFLOW_PUBLIC_BASE_URL=https://showroomflow.promotekk.com
SHOWROOMFLOW_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
SHOWROOMFLOW_SECRET_KEY=replace-with-at-least-32-random-characters
SHOWROOMFLOW_ACCESS_TOKEN_MINUTES=30
SHOWROOMFLOW_REFRESH_TOKEN_DAYS=30
SHOWROOMFLOW_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SHOWROOMFLOW_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
SHOWROOMFLOW_DATABASE_URL=postgresql+psycopg://showroomflow:showroomflow@db:5432/showroomflow
SHOWROOMFLOW_REDIS_URL=redis://redis:6379/0
SHOWROOMFLOW_STORAGE_ENDPOINT=http://minio:9000
SHOWROOMFLOW_STORAGE_ACCESS_KEY=showroomflow
SHOWROOMFLOW_STORAGE_SECRET_KEY=replace-this-storage-secret
SHOWROOMFLOW_STORAGE_BUCKET=showroomflow
SHOWROOMFLOW_RETENTION_DAYS=90
SHOWROOMFLOW_PROCESSING_PROVIDER=disabled
SHOWROOMFLOW_REMOVE_BG_SIZE=preview
SHOWROOMFLOW_PROCESSING_QUEUE=showroomflow-processing
SHOWROOMFLOW_OUTPUT_WIDTH=1920
SHOWROOMFLOW_OUTPUT_HEIGHT=1440
