SHOWROOMFLOW_ENVIRONMENT=production
SHOWROOMFLOW_PUBLIC_BASE_URL=https://showroomflow.promotekk.com
SHOWROOMFLOW_ALLOWED_HOSTS=showroomflow.promotekk.com,localhost,127.0.0.1
SHOWROOMFLOW_SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
SHOWROOMFLOW_ACCESS_TOKEN_MINUTES=30
SHOWROOMFLOW_REFRESH_TOKEN_DAYS=30

# Only required for the very first start. Remove both values after login succeeds.
SHOWROOMFLOW_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SHOWROOMFLOW_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

SHOWROOMFLOW_POSTGRES_DB=showroomflow
SHOWROOMFLOW_POSTGRES_USER=showroomflow
SHOWROOMFLOW_POSTGRES_PASSWORD=replace-with-a-random-database-password
SHOWROOMFLOW_DATABASE_URL=postgresql+psycopg://showroomflow:replace-with-url-encoded-password@db:5432/showroomflow

SHOWROOMFLOW_REDIS_PASSWORD=replace-with-a-random-redis-password
SHOWROOMFLOW_REDIS_URL=redis://:replace-with-url-encoded-password@redis:6379/0

SHOWROOMFLOW_STORAGE_ENDPOINT=https://replace-with-s3-endpoint
SHOWROOMFLOW_STORAGE_REGION=replace-with-s3-region
SHOWROOMFLOW_STORAGE_ACCESS_KEY=replace-with-s3-access-key
SHOWROOMFLOW_STORAGE_SECRET_KEY=replace-with-s3-secret-key
SHOWROOMFLOW_STORAGE_BUCKET=showroomflow-production
SHOWROOMFLOW_RETENTION_DAYS=90
